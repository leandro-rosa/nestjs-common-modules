{
  "name": "@l-rosa/prisma-db-client",
  "version": "0.1.0",
  "description": "Reusable NestJS Prisma DB client module",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^6.0.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/config": "^3.0.0 || ^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
