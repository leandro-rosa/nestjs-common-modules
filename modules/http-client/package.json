{
  "name": "@l-rosa/http-client",
  "version": "0.1.0",
  "description": "Reusable NestJS HTTP client module",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "class-validator": "^0.14.0"
  },
  "peerDependencies": {
    "@nestjs/axios": "^3.0.0 || ^4.0.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "rxjs": "^7.8.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
