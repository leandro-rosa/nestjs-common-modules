{
  "name": "@leandro-rosa/hold-it",
  "version": "0.1.0",
  "description": "Reusable NestJS job and broker module",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@bull-board/api": "^6.0.0",
    "@bull-board/fastify": "^6.0.0",
    "@elastic/elasticsearch": "^8.0.0",
    "@kafkajs/confluent-schema-registry": "^3.0.0",
    "@leandro-rosa/elasticsearch": "0.1.0",
    "avsc": "^5.7.0",
    "bull": "^4.0.0",
    "bullmq": "^5.0.0",
    "kafkajs": "^2.2.0"
  },
  "peerDependencies": {
    "@nestjs/bullmq": "^10.0.0 || ^11.0.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/config": "^3.0.0 || ^4.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestjs/event-emitter": "^2.0.0 || ^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
