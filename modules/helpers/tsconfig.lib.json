{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "noUncheckedIndexedAccess": false,
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "../../node_modules/.cache/tsbuildinfo/helpers.tsbuildinfo"
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*spec.ts",
    "src/prisma/entities-generator/**/*",
    "src/prisma/resolver-generator/**/*"
  ]
}
