{
  "name": "@leandro-rosa/nestjs-common-modules",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable NestJS common modules",
  "license": "MIT",
  "type": "commonjs",
  "workspaces": [
    "modules/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "clean": "rm -rf modules/*/dist coverage",
    "lint": "eslint \"modules/**/*.ts\"",
    "test": "jest",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "prepare:all": "npm run clean && npm run typecheck && npm run build"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jest": "^30.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.8.0"
  }
}
